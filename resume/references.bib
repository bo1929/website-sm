@article{Akbari2018,
	title = {Identifying the favored mutation in a positive selective sweep},
	volume = {15},
	issn = {1548-7091},
	url = {http://www.nature.com/doifinder/10.1038/nmeth.4606},
	doi = {10.1038/nmeth.4606},
	abstract = {Most approaches that capture signatures of selective sweeps in population genomics data do not identify the specific mutation favored by selection. We present iSAFE (for "integrated selection of allele favored by evolution"), a method that enables researchers to accurately pinpoint the favored mutation in a large region (â 1/45 Mbp) by using a statistic derived solely from population genetics signals. iSAFE does not require knowledge of demography, the phenotype under selection, or functional annotations of mutations.},
