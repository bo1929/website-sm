@article{onekp,
	title = {One thousand plant transcriptomes and the phylogenomics of green plants},
	volume = {574},
	issn = {0028-0836},
	url = {https://doi.org/10.1038/s41586-019-1693-2},
	doi = {10.1038/s41586-019-1693-2},
	abstract = {Green plants (Viridiplantae) include around 450,000–500,000 species1,2 of great diversity and have important roles in terrestrial and aquatic ecosystems. Here, as part of the One Thousand Plant Transcriptomes Initiative, we sequenced the vegetative transcriptomes of 1,124 species that span the diversity of plants in a broad sense (Archaeplastida), including green plants (Viridiplantae), glaucophytes (Glaucophyta) and red algae (Rhodophyta). Our analysis provides a robust phylogenomic framework for examining the evolution of green plants. Most inferred species relationships are well supported across multiple species tree and supermatrix analyses, but discordance among plastid and nuclear gene trees at a few important nodes highlights the complexity of plant genome evolution, including polyploidy, periods of rapid speciation, and extinction. Incomplete sorting of ancestral variation, polyploidization and massive expansions of gene families punctuate the evolutionary history of green plants. Notably, we find that large expansions of gene families preceded the origins of green plants, land plants and vascular plants, whereas whole-genome duplications are inferred to have occurred repeatedly throughout the evolution of flowering plants and ferns. The increasing availability of high-quality plant genome sequences and advances in functional genomics are enabling research on genome evolution across the green tree of life.},
	number = {7780},
	journal = {Nature},
	author = {Leebens-Mack, James H and Barker, Michael S and Carpenter, Eric J and Deyholos, Michael K and Gitzendanner, Matthew A and Graham, Sean W and Grosse, Ivo and Li, Zheng and Melkonian, Michael and Mirarab, Siavash and Porsch, Martin and Quint, Marcel and Rensing, Stefan A and Soltis, Douglas E and Soltis, Pamela S and Stevenson, Dennis W and Ullrich, Kristian K and Wickett, Norman J and DeGironimo, Lisa and Edger, Patrick P and Jordon-Thaden, Ingrid E and Joya, Steve and Liu, Tao and Melkonian, Barbara and Miles, Nicholas W and Pokorny, Lisa and Quigley, Charlotte and Thomas, Philip and Villarreal, Juan Carlos and Augustin, Megan M and Barrett, Matthew D and Baucom, Regina S and Beerling, David J and Benstein, Ruben Maximilian and Biffin, Ed and Brockington, Samuel F and Burge, Dylan O and Burris, Jason N and Burris, Kellie P and Burtet-Sarramegna, Valérie and Caicedo, Ana L and Cannon, Steven B and Çebi, Zehra and Chang, Ying and Chater, Caspar and Cheeseman, John M and Chen, Tao and Clarke, Neil D and Clayton, Harmony and Covshoff, Sarah and Crandall-Stotler, Barbara J and Cross, Hugh and DePamphilis, Claude W and Der, Joshua P and Determann, Ron and Dickson, Rowan C and Di Stilio, Verónica S and Ellis, Shona and Fast, Eva and Feja, Nicole and Field, Katie J and Filatov, Dmitry A and Finnegan, Patrick M and Floyd, Sandra K and Fogliani, Bruno and García, Nicolás and Gâteblé, Gildas and Godden, Grant T and Goh, Falicia (Qi Yun) and Greiner, Stephan and Harkess, Alex and Heaney, James Mike and Helliwell, Katherine E and Heyduk, Karolina and Hibberd, Julian M and Hodel, Richard G J and Hollingsworth, Peter M and Johnson, Marc T J and Jost, Ricarda and Joyce, Blake and Kapralov, Maxim V and Kazamia, Elena and Kellogg, Elizabeth A and Koch, Marcus A and Von Konrat, Matt and Könyves, Kálmán and Kutchan, Toni M and Lam, Vivienne and Larsson, Anders and Leitch, Andrew R and Lentz, Roswitha and Li, Fay-Wei and Lowe, Andrew J and Ludwig, Martha and Manos, Paul S and